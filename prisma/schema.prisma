// Prisma schema — single-user job application tracker (local SQLite).
// SQLite has no native enums, so enum-like fields are Strings validated in app code
// (see lib/types.ts for the canonical value sets).

generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "sqlite"
	url      = env("DATABASE_URL")
}

model Application {
	id              String    @id @default(cuid())
	title           String
	company         String
	platform        String    @default("SEEK") // SEEK | LinkedIn | Indeed | Other
	url             String?
	location        String? // free-text as captured, e.g. "Wollongong NSW 2500"
	postcode        String?
	state           String?
	isRegionalNSW   Boolean   @default(false)
	regionMatchType String    @default("none") // postcode | suburb | none
	salaryMin       Int?
	salaryMax       Int?
	salaryText      String?
	status          String    @default("Saved") // Saved | Applied | Interview | Offer | Rejected
	statusOrder     Int       @default(0) // position within its kanban column
	dateApplied     DateTime?
	notes           String?
	description     String? // full job-description text (for resume-match scoring)
	source          String    @default("manual") // manual | url-fetch | extension
	matchScore      Int? // 0-100 resume-match score (Phase 4); null = not yet scored
	matchedSkills   String? // JSON array of resume skills found in this job
	missingSkills   String? // JSON array of job keywords the resume lacks
	createdAt       DateTime  @default(now())
	updatedAt       DateTime  @updatedAt

	history StatusHistory[]
}

// Single-row table (id = "singleton") holding the user's resume + derived skills,
// used to score how well each job matches. One resume at a time by design.
model Profile {
	id         String   @id @default("singleton")
	resumeText String   @default("")
	resumeName String? // source filename, shown in the UI
	skills     String   @default("[]") // JSON array of extracted skill keywords
	updatedAt  DateTime @updatedAt
}

model StatusHistory {
	id            String      @id @default(cuid())
	applicationId String
	application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
	fromStatus    String?
	toStatus      String
	changedAt     DateTime    @default(now())

	@@index([applicationId])
}
