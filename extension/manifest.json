{
	"manifest_version": 3,
	"name": "JobTrackr — Save Job",
	"version": "0.2.0",
	"description": "One-click save of a SEEK / LinkedIn / Indeed job into your local JobTrackr board, with regional-NSW auto-tagging and a weekly new-job alert.",
	"permissions": ["activeTab", "scripting", "storage", "alarms", "notifications", "tabs"],
	"host_permissions": ["http://localhost/*", "http://127.0.0.1/*", "https://au.seek.com/*", "https://www.seek.com.au/*"],
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_title": "Save this job to JobTrackr",
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	}
}
